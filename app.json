{
    "expo": {
        "name": "RentalApp Tenant Mobile",
        "slug": "rental-app-tenant-mobile",
        "scheme": "tenantportal",
        "version": "1.0.0",
        "orientation": "portrait",
        "userInterfaceStyle": "light",
        "assetBundlePatterns": ["**/*"],
        "splash": {
            "image": "./assets/logo.png",
            "resizeMode": "contain",
            "backgroundColor": "#FFFFFF"
        },
        "ios": {
            "supportsTablet": true,
            "bundleIdentifier": "com.rentalapp.tenantmobile"
        },
        "android": {
            "package": "com.rentalapp.tenantmobile"
        },
        "web": {
            "bundler": "metro",
            "output": "static"
        },
        "plugins": ["expo-router", "expo-secure-store"],
        "experiments": {
            "typedRoutes": true
        }
    }
}
